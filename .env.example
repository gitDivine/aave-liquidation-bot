# ============================================================
#  LIQUIDATION BOT — CONFIGURATION
#  Copy this file to .env and fill in your values
#  NEVER share your .env file or commit it to GitHub
# ============================================================

# ── YOUR WALLET ──────────────────────────────────────────────
# The private key of the wallet that deployed the contract
# Get from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# ── ALCHEMY API ───────────────────────────────────────────────
# Get free key at: alchemy.com → Create App → Base (or Arbitrum)
# Use the WebSocket URL (starts with wss://)
ALCHEMY_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Also add the HTTPS URL for non-streaming calls
ALCHEMY_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# ── YOUR DEPLOYED CONTRACT ────────────────────────────────────
# The address you get after deploying LiquidationBot.sol in Remix
# Looks like: 0x1234...abcd
CONTRACT_ADDRESS=your_deployed_contract_address_here

# ── CHAIN SELECTION ───────────────────────────────────────────
# Options: base | arbitrum | polygon
CHAIN=base

# ── PROFIT SETTINGS ───────────────────────────────────────────
# Minimum profit in USD before bot fires (protects against gas waste)
MIN_PROFIT_USD=10

# Maximum gas price in gwei before bot skips (avoid overpaying gas)
MAX_GAS_GWEI=50

# ── NOTIFICATION (optional) ───────────────────────────────────
# Get Telegram bot token from @BotFather and your chat ID
# Leave blank to disable notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
